# Fastfile for TranslateKB.
#
# Auth:
#   The lanes below use App Store Connect API key for non-interactive auth.
#   One-time setup:
#     1. App Store Connect → Users and Access → Integrations → App Store
#        Connect API → Keys → "+" → Admin role → download AuthKey_<ID>.p8
#     2. Put the .p8 at: ~/.appstoreconnect/private_keys/AuthKey_<ID>.p8
#     3. Export env vars:
#          export ASC_KEY_ID=ABCDEF1234
#          export ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
#          export APPLE_ID=you@example.com
#
# Common usage:
#   bundle exec fastlane create_app   # one-time: creates ASC record + App ID
#   bundle exec fastlane sync_metadata  # uploads description/keywords/etc
#   bundle exec fastlane sync_screenshots
#   bundle exec fastlane beta           # archive + upload to TestFlight
#   bundle exec fastlane release        # submit current build for App Store review

default_platform(:ios)

# Resolve the App Store Connect API key from env every time, so a missing
# value gives a clear error instead of falling back to interactive 2FA.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8"),
    duration: 1200,
    in_house: false
  )
end

platform :ios do

  desc "One-time: create the App Store Connect record + Developer Portal App IDs."
  lane :create_app do
    # Container app
    produce(
      app_identifier: "com.aminbenarieb.translatekeyboard",
      app_name: "TranslateKB",
      language: "English",
      app_version: "0.1.0",
      sku: "translatekb-ios",
      enable_services: { app_group: "on" }
    )
    # Keyboard extension App ID (no ASC record needed for extensions)
    produce(
      app_identifier: "com.aminbenarieb.translatekeyboard.keyboard",
      app_name: "TranslateKB Keyboard",
      skip_itc: true,
      language: "English",
      enable_services: { app_group: "on" }
    )
  end

  desc "Sync app description, keywords, URLs to App Store Connect (no upload)."
  lane :sync_metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload screenshots from Distribution/screenshots to App Store Connect."
  lane :sync_screenshots do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true
    )
  end

  desc "Archive a Release build and upload to TestFlight."
  lane :beta do
    sh "cd .. && tuist generate --no-open"

    build_app(
      workspace: "TranslationKeyboard.xcworkspace",
      scheme: "TranslationKeyboard",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "TranslationKeyboard.ipa",
      clean: true,
      include_bitcode: false,
      include_symbols: true,
      export_options: {
        method: "app-store-connect",
        teamID: "5P8935L6RT",
        signingStyle: "automatic",
        uploadSymbols: true,
        stripSwiftSymbols: true
      }
    )

    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: false,
      changelog: File.read("../Distribution/metadata/en-US/promotional_text.txt").strip
    )
  end

  desc "Submit the latest TestFlight build for App Store review."
  lane :release do
    deliver(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: false,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false
      }
    )
  end
end
